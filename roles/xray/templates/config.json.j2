{
  "inbounds": [
    {
      "listen": null,
      "port": {{ xray_server.port }},
      "protocol": "vless",
      "settings": {
        "clients": [
          {% for uuid in xray_server.uuids %}
            {
              "email": "{{ uuid }}",
              "flow": "xtls-rprx-vision",
              "id": "{{ uuid }}"
            }
            {% if not loop.last %}
              ,
            {% endif %}
          {% endfor %}
        ],
        "decryption": "none",
        "fallbacks": []
      },
      "streamSettings": {
        "network": "tcp",
        "realitySettings": {
          "dest": "{{ xray_server.fallback_proxy_target }}",
          "maxTimediff": 0,
          "privateKey": "{{ xray_server.private_key }}",
          "serverNames": {{ xray_server.snis | to_json }},
          "shortIds": [""],
          "show": false,
          "xver": 0
        },
        "security": "reality",
        "tcpSettings": {
          "acceptProxyProtocol": false,
          "header": {
            "type": "none"
          }
        }
      },
      "tag": "inbound-vless",
      "sniffing": {
        "enabled": false
      },
      "allocate": {
        "strategy": "always",
        "refresh": 5,
        "concurrency": 3
      }
    }
  ],
  "outbounds": [
    {% if xray_next_server is not none %}
      {
        "tag": "next-hop",
        "protocol": "vless",
        "settings": {
          "vnext": [
            {
              "address": "{{ xray_next_server.host }}",
              "port": {{ xray_next_server.port }},
              "users": [
                {
                  "id": "{{ xray_next_server.uuids | first }}",
                  "email": "{{ xray_next_server.uuids | first }}",
                  "flow": "xtls-rprx-vision",
                  "encryption": "none"
                }
              ]
            }
          ]
        },
        "streamSettings": {
          "network": "tcp",
          "security": "reality",
          "realitySettings": {
            "fingerprint": "{{ xray_next_server.fingerprint }}",
            "serverName": "{{ xray_next_server.snis | first }}",
            "publicKey": "{{ xray_next_server.public_key }}",
            "shortId": "",
            "spiderX": ""
          }
        }
      },
    {% endif %}
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "blocked",
      "protocol": "blackhole",
      "settings": {}
    }
  ],

  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "inboundTag": [
          "inbound-vless"
        ],
        "outboundTag": "blocked",
        "domain": [
          "geosite:category-ru"
        ]
      },
      {
        "inboundTag": [
          "inbound-vless"
        ],
        "outboundTag": "blocked",
        "ip": [
          "geoip:private",
          "geoip:ru"
        ]
      }
    ]
  },

  "log": {
    "access": "none",
    "dnsLog": false,
    "error": "/home/{{ xray_user }}/{{ xray_error_log_file_name }}",
    "loglevel": "warning",
    "maskAddress": ""
  }
}
